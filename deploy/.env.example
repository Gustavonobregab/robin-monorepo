# Copiar para /opt/robin/shared/.env na VPS (chmod 600, dono robin:robin).
# NUNCA commitar o .env real.

# --- Runtime ---
NODE_ENV=production
CLIENT_URL=https://robinzip.app
API_RATE_LIMIT_PER_MINUTE=60

# --- Infra ---
# Atlas M0: adicionar o IP da VPS (179.197.226.79) na allowlist
MONGODB_URI=
REDIS_URL=redis://redis:6379

# --- Workers (tuning p/ 2 vCPU; medir e ajustar) ---
AUDIO_WORKER_CONCURRENCY=1
IMAGE_WORKER_CONCURRENCY=2
TEXT_WORKER_CONCURRENCY=2

# --- Auth ---
# gerar: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=https://api.robinzip.app
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Billing ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
ABACATEPAY_API_KEY=
ABACATEPAY_BASE_URL=https://api.abacatepay.com
ABACATEPAY_WEBHOOK_SECRET=

# --- Storage (Cloudflare R2) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
